<Window x:Class="ModSorter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ModSorter v0.1" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabs" Grid.Row="0" BorderThickness="0"
                    Background="{StaticResource BgDark}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            <!-- ===== Tab 0: トップメニュー ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <StackPanel Margin="14,24,14,0">
                            <TextBlock Text="ModSorter" FontSize="22"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"
                                       Margin="0,0,0,24"/>
                            <Button Content="Modsフォルダ" Style="{StaticResource McButton}"
                                    Margin="0,0,0,10" Click="NavMods_Click"/>
                            <Button Content="クラッシュレポート" Style="{StaticResource McButtonGray}"
                                    Margin="0,0,0,10" Click="NavCrash_Click"/>
                            <Button Content="設定" Style="{StaticResource McButtonGray}"
                                    Click="NavSettings_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgDark}">
                        <TextBlock Text="左のメニューから操作を選んでください"
                                   Style="{StaticResource PixelText}"
                                   Foreground="{StaticResource TextDim}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Tab 1: Mods ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" MinWidth="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="320" MinWidth="220"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <DockPanel>
                            <Button DockPanel.Dock="Top" Content="← 戻る"
                                    Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Margin="10"
                                    Click="Back_Click"/>
                            <Button DockPanel.Dock="Top" Content="スキャン"
                                    Style="{StaticResource McButton}"
                                    Margin="10,0,10,10" Click="Scan_Click"/>
                            <ProgressBar DockPanel.Dock="Top" x:Name="ScanProgress"
                                         Height="14" Margin="10,0,10,4"
                                         Minimum="0" Maximum="100" Value="0"
                                         Foreground="{StaticResource GrassGreen}"
                                         Background="{StaticResource StoneDark}"
                                         Visibility="Collapsed"/>
                            <TextBlock DockPanel.Dock="Top" x:Name="ScanStatus"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11" Margin="10,0,10,8"
                                       TextWrapping="Wrap" Text=""/>

                            <TreeView x:Name="ModTree" Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="{StaticResource TextMain}"
                                      SelectedItemChanged="ModTree_SelectedItemChanged"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <Border Grid.Column="2" Background="{StaticResource BgDark}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="8,8,8,4">
                                <Button Content="大" Style="{StaticResource McButtonGray}"
                                        Margin="0,0,6,0" Click="ViewLarge_Click"/>
                                <Button Content="中" Style="{StaticResource McButtonGray}"
                                        Margin="0,0,6,0" Click="ViewMedium_Click"/>
                                <Button Content="一覧" Style="{StaticResource McButtonGray}"
                                        Click="ViewList_Click"/>
                            </StackPanel>
                            <ListBox x:Name="CardList" Background="Transparent"
                                     BorderThickness="0" Padding="6"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="CardList_SelectionChanged"
                                     ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                     HorizontalContentAlignment="Stretch"/>


                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <Border Grid.Column="4" Background="{StaticResource BgPanel}" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="詳細" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" Margin="0,0,0,10"/>
                                <TextBlock x:Name="DetailName" Style="{StaticResource PixelText}"
                                           FontSize="16" TextWrapping="Wrap" Text="(MODを選択)"/>
                                <TextBlock x:Name="DetailId" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,8,0,0"/>
                                <TextBlock x:Name="DetailVersion" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="DetailLoader" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,4,0,12"/>

                                <TextBlock Text="説明" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <wv2:WebView2 x:Name="DetailWeb" Height="320"
                                              Margin="0,4,0,12"/>

                                <TextBlock Text="MODページ" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBlock x:Name="UrlCurseForge" Style="{StaticResource PixelText}"
                                           Foreground="#E69138" TextWrapping="Wrap"
                                           Cursor="Hand" Margin="0,4,0,0"
                                           MouseLeftButtonUp="UrlCf_Click"
                                           Text="CurseForge: (なし)"/>
                                <TextBlock x:Name="UrlModrinth" Style="{StaticResource PixelText}"
                                           Foreground="#1BD96A" TextWrapping="Wrap"
                                           Cursor="Hand" Margin="0,4,0,0"
                                           MouseLeftButtonUp="UrlMr_Click"
                                           Text="Modrinth: (なし)"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Tab 2: クラッシュレポート ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <DockPanel>
                            <Button DockPanel.Dock="Top" Content="← 戻る"
                                    Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Margin="10"
                                    Click="Back_Click"/>
                            <TextBlock DockPanel.Dock="Top" Text="クラッシュレポート"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"
                                       Margin="10,0,10,6"/>
                            <ListBox x:Name="CrashFileList" Background="Transparent"
                                     BorderThickness="0" Foreground="{StaticResource TextMain}"
                                     SelectionChanged="CrashFile_Selected"/>
                        </DockPanel>
                    </Border>
                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>
                    <Border Grid.Column="2" Background="{StaticResource BgDark}" Padding="12">
                        <DockPanel>
                            <Button DockPanel.Dock="Top" Content="このレポートを解析"
                                    Style="{StaticResource McButton}"
                                    HorizontalAlignment="Left" Margin="0,0,0,10"
                                    Click="AnalyzeCrash_Click"/>
                            <TextBox x:Name="CrashResult" IsReadOnly="True"
                                     Background="{StaticResource BgPanel}"
                                     Foreground="{StaticResource TextMain}"
                                     BorderThickness="0" FontFamily="{StaticResource PixelFont}"
                                     FontSize="12" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" Padding="10"
                                     Text="(レポートを選択し「解析」を押すと原因候補を表示)"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Tab 3: 設定 ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <StackPanel Margin="10">
                            <Button Content="← 戻る" Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Click="Back_Click"/>
                            <TextBlock Text="設定" FontSize="18" Margin="0,20,0,0"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgDark}" Padding="24">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text=".minecraft フォルダ" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <Grid Margin="0,4,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="PathBox" IsReadOnly="True"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="選択..."
                                        Style="{StaticResource McButtonGray}"
                                        Margin="8,0,0,0" Click="SelectFolder_Click"/>
                            </Grid>

                            <TextBlock Text="CurseForge APIキー" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <PasswordBox x:Name="CfKeyBox" Margin="0,4,0,16"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"/>

                            <TextBlock Text="DeepL APIキー" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <PasswordBox x:Name="DeepLKeyBox" Margin="0,4,0,16"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"/>

                            <Button Content="保存" Style="{StaticResource McButton}"
                                    HorizontalAlignment="Left" Click="SaveSettings_Click"/>
                            <TextBlock x:Name="SettingsStatus" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Background="{StaticResource BgPanel}" Height="120">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="ログ" Padding="10,4"
                           Style="{StaticResource PixelText}"
                           Foreground="{StaticResource GrassGreen}"/>
                <TextBox x:Name="LogBox" IsReadOnly="True"
                         Background="{StaticResource BgDark}"
                         Foreground="{StaticResource TextMain}" BorderThickness="0"
                         FontFamily="{StaticResource PixelFont}" FontSize="11"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         Padding="10,0,10,8"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
