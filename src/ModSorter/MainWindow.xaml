<Window x:Class="ModSorter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ModSorter v0.1" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabs" Grid.Row="0" BorderThickness="0"
                    Background="{StaticResource BgDark}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            <!-- ===== Tab 0: トップメニュー ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <StackPanel Margin="14,24,14,0">
                            <TextBlock Text="ModSorter" FontSize="22"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"
                                       Margin="0,0,0,24"/>
                            <Button Content="Modsフォルダ" Style="{StaticResource McButton}"
                                    Margin="0,0,0,10" Click="NavMods_Click"/>
                            <Button Content="クラッシュレポート" Style="{StaticResource McButtonGray}"
                                    Margin="0,0,0,10" Click="NavCrash_Click"/>
                            <Button Content="設定" Style="{StaticResource McButtonGray}"
                                    Click="NavSettings_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgDark}">
                        <DockPanel Margin="24">
                            <TextBlock DockPanel.Dock="Top" Text="最近の動作"
                                       FontSize="18"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"
                                       Margin="0,0,0,12"/>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="左のメニューから操作を選んでください"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="12" Margin="0,0,0,12"/>
                            <ListBox x:Name="ActivityList" Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextMain}"
                                     ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </DockPanel>
                    </Border>

                </Grid>
            </TabItem>

            <!-- ===== Tab 1: Mods ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" MinWidth="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="420" MinWidth="320"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <DockPanel>
                            <Button DockPanel.Dock="Top" Content="← 戻る"
                                    Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Margin="10"
                                    Click="Back_Click"/>
                            <Button DockPanel.Dock="Top" Content="スキャン"
                                    Style="{StaticResource McButton}"
                                    Margin="10,0,10,10" Click="Scan_Click"/>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="10,0,10,10">
                                <Button x:Name="ViewAllBtn" Content="すべて表示"
                                        Style="{StaticResource McButtonGray}"
                                        Margin="0,0,6,0" Click="ViewAll_Click"/>
                                <Button x:Name="ViewByCategoryBtn" Content="カテゴリ表示"
                                        Style="{StaticResource McButtonGray}"
                                        Click="ViewByCategory_Click"/>
                            </StackPanel>

                            <ProgressBar DockPanel.Dock="Top" x:Name="ScanProgress"
                                         Height="14" Margin="10,0,10,4"
                                         Minimum="0" Maximum="100" Value="0"
                                         Foreground="{StaticResource GrassGreen}"
                                         Background="{StaticResource StoneDark}"
                                         Visibility="Collapsed"/>
                            <TextBlock DockPanel.Dock="Top" x:Name="ScanStatus"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11" Margin="10,0,10,8"
                                       TextWrapping="Wrap" Text=""/>

                            <TreeView x:Name="ModTree" Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="{StaticResource TextMain}"
                                      SelectedItemChanged="ModTree_SelectedItemChanged"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <Border Grid.Column="2" Background="{StaticResource BgDark}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4">
                                <!-- 左: 表示切替と並び順 -->
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Button Content="大" Style="{StaticResource McButtonGray}"
                                            Margin="0,0,6,0" Click="ViewLarge_Click"/>
                                    <Button Content="中" Style="{StaticResource McButtonGray}"
                                            Margin="0,0,6,0" Click="ViewMedium_Click"/>
                                    <Button Content="一覧" Style="{StaticResource McButtonGray}"
                                            Click="ViewList_Click"/>
                                    <TextBlock Text="並び順:" Style="{StaticResource PixelText}"
                                               VerticalAlignment="Center" Margin="16,0,4,0"/>
                                    <ComboBox x:Name="SortCombo" Width="160"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource McComboBox}"
                                              SelectionChanged="SortCombo_SelectionChanged">
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="名称順（昇順）" IsSelected="True"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="名称順（降順）"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="カテゴリ順"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="ファイル更新日順"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="ファイルサイズ順"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="追加日順"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="ローダー順"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- 右: 選択モード開始ボタンのみ -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="SelectModeBtn" Content="選択"
                                            Style="{StaticResource McButtonGray}"
                                            Click="SelectMode_Click"/>
                                </StackPanel>

                            </DockPanel>
                            <!-- 検索行 -->
                            <DockPanel DockPanel.Dock="Top" Margin="8,0,8,6">
                                <TextBlock Text="検索:" Style="{StaticResource PixelText}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            Margin="8,0,0,0">
                                    <RadioButton x:Name="SearchAndRadio" Content="AND"
                                                 GroupName="SearchMode" IsChecked="True"
                                                 Foreground="{StaticResource TextMain}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Checked="SearchMode_Changed"/>
                                    <RadioButton x:Name="SearchOrRadio" Content="OR"
                                                 GroupName="SearchMode"
                                                 Foreground="{StaticResource TextMain}"
                                                 VerticalAlignment="Center"
                                                 Checked="SearchMode_Changed"/>
                                </StackPanel>
                                <TextBox x:Name="SearchBox"
                                         Background="{StaticResource BgCard}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         BorderThickness="0" Padding="6,3"
                                         VerticalContentAlignment="Center"
                                         TextChanged="SearchBox_TextChanged"/>
                            </DockPanel>

                            <!-- ===== カバーアート帯（軽量カルーセル） ===== -->
                            <Border DockPanel.Dock="Top" Height="150" Margin="8,0,8,8"
                                    Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource StoneDark}" BorderThickness="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="CoverCanvas" ClipToBounds="True"
                                        Background="Transparent"
                                        SizeChanged="CoverCanvas_SizeChanged"
                                        MouseLeftButtonDown="CoverCanvas_MouseDown"
                                        MouseMove="CoverCanvas_MouseMove"
                                        MouseLeftButtonUp="CoverCanvas_MouseUp"
                                        MouseLeave="CoverCanvas_MouseLeave"/>
                            </Border>

                            <ListBox x:Name="CardList" Background="Transparent"
                                     BorderThickness="0" Padding="6"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="CardList_SelectionChanged"
                                     ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                     HorizontalContentAlignment="Stretch"/>


                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <Border Grid.Column="4" Background="{StaticResource BgPanel}" Padding="12">
                        <Grid>
                            <!-- ===== 詳細パネル（通常モード） ===== -->
                            <ScrollViewer x:Name="DetailPanel" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="詳細" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource GrassGreen}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="DetailName" Style="{StaticResource PixelText}"
                                               FontSize="16" TextWrapping="Wrap" Text="(MODを選択)"/>
                                    <TextBlock x:Name="DetailId" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}" Margin="0,8,0,0"/>
                                    <TextBlock x:Name="DetailVersion" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="DetailLoader" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}" Margin="0,4,0,12"/>
                                    <TextBlock x:Name="DetailCategory" Style="{StaticResource PixelText}"
                                               TextWrapping="Wrap" Margin="0,2,0,0"/>

                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="説明"
                                                   Style="{StaticResource PixelText}"
                                                   Foreground="{StaticResource GrassGreen}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="TranslateBtn" Content="翻訳"
                                                Style="{StaticResource McButtonGray}"
                                                Click="Translate_Click"/>
                                    </Grid>
                                    <wv2:WebView2 x:Name="DetailWeb" Height="320"
                                                  Margin="0,4,0,12"/>

                                    <TextBlock Text="MODページ" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource GrassGreen}"/>
                                    <TextBlock x:Name="UrlCurseForge" Style="{StaticResource PixelText}"
                                               Foreground="#E69138" TextWrapping="Wrap"
                                               Cursor="Hand" Margin="0,4,0,0"
                                               MouseLeftButtonUp="UrlCf_Click"
                                               Text="CurseForge: (なし)"/>
                                    <TextBlock x:Name="UrlModrinth" Style="{StaticResource PixelText}"
                                               Foreground="#1BD96A" TextWrapping="Wrap"
                                               Cursor="Hand" Margin="0,4,0,0"
                                               MouseLeftButtonUp="UrlMr_Click"
                                               Text="Modrinth: (なし)"/>
                                    <Button x:Name="RefetchBtn" Content="このMODを再取得"
                                            Style="{StaticResource McButtonGray}"
                                            HorizontalAlignment="Left" Margin="0,16,0,0"
                                            Click="Refetch_Click"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ===== 取得モードパネル ===== -->
                            <DockPanel x:Name="SelectionPanel" Visibility="Collapsed">
                                <TextBlock DockPanel.Dock="Top" Text="取得モード"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" Margin="0,0,0,10"/>

                                <!-- ボタン: 上2行は2列、最下行に選択終了 -->
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Content="全選択"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="0,0,4,4" Click="SelectAll_Click"/>
                                    <Button Grid.Row="0" Grid.Column="1" Content="全解除"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="4,0,0,4" Click="SelectNone_Click"/>
                                    <Button Grid.Row="1" Grid.Column="0" x:Name="RefetchSelectedBtn"
                                            Content="選択を再取得(0件)"
                                            Style="{StaticResource McButton}"
                                            Margin="0,4,4,4" Click="RefetchSelected_Click"/>
                                    <Button Grid.Row="1" Grid.Column="1" x:Name="OllamaSelectedBtn"
                                            Content="Ollama取得(0件)"
                                            Style="{StaticResource McButton}"
                                            Margin="4,4,0,4" Click="OllamaSelected_Click"/>
                                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                            Content="選択終了"
                                            Style="{StaticResource McButtonRed}"
                                            Margin="0,4,0,0" Click="SelectMode_Click"/>
                                </Grid>

                                <TextBlock DockPanel.Dock="Top" Text="選択中のMOD"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" Margin="0,0,0,6"/>

                                <!-- 選択中MOD一覧（一覧表示と同じ ListTemplate） -->
                                <ListBox x:Name="SelectedList" Background="Transparent"
                                         BorderThickness="0" Padding="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                         HorizontalContentAlignment="Stretch"
                                         ItemTemplate="{StaticResource ListTemplate}"
                                         SelectionChanged="SelectedList_SelectionChanged"/>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Tab 2: クラッシュレポート ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="380" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左: クラッシュレポートのファイル一覧 -->
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <DockPanel>
                            <Button DockPanel.Dock="Top" Content="← 戻る"
                                    Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Margin="10"
                                    Click="Back_Click"/>
                            <TextBlock DockPanel.Dock="Top" Text="クラッシュレポート"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"
                                       Margin="10,0,10,6"/>
                            <Button DockPanel.Dock="Top" Content="このレポートを解析"
                                    Style="{StaticResource McButton}"
                                    Margin="10,0,10,10" Click="AnalyzeCrash_Click"/>
                            <ListBox x:Name="CrashFileList" Background="Transparent"
                                     BorderThickness="0" Foreground="{StaticResource TextMain}"
                                     SelectionChanged="CrashFile_Selected"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <!-- 中央: 解析した issue 一覧 -->
                    <Border Grid.Column="2" Background="{StaticResource BgDark}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" x:Name="CrashSummary"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Margin="10,10,10,8"
                                       Text="(レポートを選び「このレポートを解析」を押してください)"/>
                            <ListBox x:Name="CrashIssueList" Background="Transparent"
                                     BorderThickness="0" Padding="6"
                                     Foreground="{StaticResource TextMain}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                     HorizontalContentAlignment="Stretch"
                                     SelectionChanged="CrashIssueList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgCard}"
                                                BorderBrush="{StaticResource StoneDark}"
                                                BorderThickness="1" Margin="0,0,0,4"
                                                Padding="8,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding KindLabel}"
                                                           FontFamily="{StaticResource PixelFont}"
                                                           Foreground="{StaticResource GrassGreen}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding ModId}"
                                                           FontFamily="{StaticResource PixelFont}"
                                                           Foreground="{StaticResource TextMain}"
                                                           FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <!-- 右: 選択 issue の詳細パネル -->
                    <Border Grid.Column="4" Background="{StaticResource BgPanel}" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="詳細" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" Margin="0,0,0,10"/>

                                <!-- クラッシュ理由 -->
                                <TextBlock Text="クラッシュ原因" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" FontSize="12"/>
                                <TextBlock x:Name="CrashDetailReason" Style="{StaticResource PixelText}"
                                           TextWrapping="Wrap" Margin="0,4,0,12"
                                           Text="(中央のリストから問題を選択)"/>

                                <!-- MOD情報(スキャン済みなら表示) -->
                                <TextBlock Text="MOD情報" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" FontSize="12"/>
                                <TextBlock x:Name="CrashDetailName" Style="{StaticResource PixelText}"
                                           FontSize="15" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="―"/>
                                <TextBlock x:Name="CrashDetailId" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CrashDetailVersion" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CrashDetailLoader" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CrashDetailCategory" Style="{StaticResource PixelText}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CrashDetailFile" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,8,0,12"/>

                                <!-- MODページ -->
                                <TextBlock Text="MODページ" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" FontSize="12"/>
                                <TextBlock x:Name="CrashUrlCurseForge" Style="{StaticResource PixelText}"
                                           Foreground="#E69138" TextWrapping="Wrap"
                                           Cursor="Hand" Margin="0,4,0,0"
                                           MouseLeftButtonUp="CrashUrlCf_Click"
                                           Text="CurseForge: ―"/>
                                <TextBlock x:Name="CrashUrlModrinth" Style="{StaticResource PixelText}"
                                           Foreground="#1BD96A" TextWrapping="Wrap"
                                           Cursor="Hand" Margin="0,4,0,0"
                                           MouseLeftButtonUp="CrashUrlMr_Click"
                                           Text="Modrinth: ―"/>

                                <!-- 削除ボタン(第3段階で実装) -->
                                <Button x:Name="CrashDeleteBtn" Content="このMODを削除"
                                        Style="{StaticResource McButtonRed}"
                                        HorizontalAlignment="Left" Margin="0,20,0,0"
                                        IsEnabled="False"
                                        Click="CrashDelete_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- ===== Tab 3: 設定 ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <StackPanel Margin="10">
                            <Button Content="← 戻る" Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Click="Back_Click"/>
                            <TextBlock Text="設定" FontSize="18" Margin="0,20,0,0"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgDark}" Padding="24">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text=".minecraft フォルダ" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <Grid Margin="0,4,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="PathBox" IsReadOnly="True"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="選択..."
                                        Style="{StaticResource McButtonGray}"
                                        Margin="8,0,0,0" Click="SelectFolder_Click"/>
                            </Grid>

                            <TextBlock Text="CurseForge APIキー" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <PasswordBox x:Name="CfKeyBox" Margin="0,4,0,16"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"/>

                            <TextBlock Text="DeepL APIキー" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <PasswordBox x:Name="DeepLKeyBox" Margin="0,4,0,16"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"/>

                            <Button Content="保存" Style="{StaticResource McButton}"
                                    HorizontalAlignment="Left" Click="SaveSettings_Click"/>
                            <TextBlock x:Name="SettingsStatus" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" Margin="0,10,0,0"/>

                            <TextBlock Text="キャッシュ管理" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}" Margin="0,28,0,0"/>
                            <TextBlock Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,4,0,8"
                                       Text="MOD情報とアイコンの保存データを全て削除します。次回スキャンで再取得されます。"/>
                            <Button Content="キャッシュを全削除" Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Click="ClearCache_Click"/>
                            <TextBlock x:Name="CacheStatus" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" Margin="0,8,0,0"/>

                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Background="{StaticResource BgPanel}" Height="120">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="ログ" Padding="10,4"
                           Style="{StaticResource PixelText}"
                           Foreground="{StaticResource GrassGreen}"/>
                <TextBox x:Name="LogBox" IsReadOnly="True"
                         Background="{StaticResource BgDark}"
                         Foreground="{StaticResource TextMain}" BorderThickness="0"
                         FontFamily="{StaticResource PixelFont}" FontSize="11"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         Padding="10,0,10,8"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
