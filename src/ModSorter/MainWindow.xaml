<Window x:Class="ModSorter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ModSorter v0.1" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabs" Grid.Row="0" BorderThickness="0"
                    Background="{StaticResource BgDark}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            <!-- ===== Tab 0: トップメニュー ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <StackPanel Margin="14,24,14,0">
                            <TextBlock Text="ModSorter" FontSize="22"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"
                                       Margin="0,0,0,24"/>
                            <Button Content="Modsフォルダ" Style="{StaticResource McButton}"
                                    Margin="0,0,0,10" Click="NavMods_Click"/>
                            <Button Content="クラッシュレポート" Style="{StaticResource McButtonGray}"
                                    Margin="0,0,0,10" Click="NavCrash_Click"/>
                            <Button Content="設定" Style="{StaticResource McButtonGray}"
                                    Margin="0,0,0,10" Click="NavSettings_Click"/>
                            <Button Content="建築モード" Style="{StaticResource McButtonGray}"
                                    Click="NavArchitect_Click"/>
                            <Button Content="Create機械" Style="{StaticResource McButtonGray}"
                                    Margin="0,10,0,0" Click="NavMachine_Click"/>


                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgDark}">
                        <DockPanel Margin="24">
                            <TextBlock DockPanel.Dock="Top" Text="最近の動作"
                                       FontSize="18"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"
                                       Margin="0,0,0,12"/>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="左のメニューから操作を選んでください"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="12" Margin="0,0,0,12"/>
                            <ListBox x:Name="ActivityList" Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextMain}"
                                     ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </DockPanel>
                    </Border>

                </Grid>
            </TabItem>

            <!-- ===== Tab 1: Mods ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" MinWidth="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="420" MinWidth="320"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <DockPanel>
                            <Button DockPanel.Dock="Top" Content="← 戻る"
                                    Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Margin="10"
                                    Click="Back_Click"/>
                            <Button DockPanel.Dock="Top" Content="スキャン"
                                    Style="{StaticResource McButton}"
                                    Margin="10,0,10,10" Click="Scan_Click"/>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="10,0,10,10">
                                <Button x:Name="ViewAllBtn" Content="すべて表示"
                                        Style="{StaticResource McButtonGray}"
                                        Margin="0,0,6,0" Click="ViewAll_Click"/>
                                <Button x:Name="ViewByCategoryBtn" Content="カテゴリ表示"
                                        Style="{StaticResource McButtonGray}"
                                        Click="ViewByCategory_Click"/>
                            </StackPanel>

                            <ProgressBar DockPanel.Dock="Top" x:Name="ScanProgress"
                                         Height="14" Margin="10,0,10,4"
                                         Minimum="0" Maximum="100" Value="0"
                                         Foreground="{StaticResource GrassGreen}"
                                         Background="{StaticResource StoneDark}"
                                         Visibility="Collapsed"/>
                            <TextBlock DockPanel.Dock="Top" x:Name="ScanStatus"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11" Margin="10,0,10,8"
                                       TextWrapping="Wrap" Text=""/>

                            <!-- ===== 日本語化パック生成パネル(追加) ===== -->
                            <Border DockPanel.Dock="Top" Margin="10,4,10,8"
                                    Background="{StaticResource BgPanel}"
                                    Padding="8">
                                <StackPanel>
                                    <TextBlock Text="日本語化パック生成(DeepL)"
                                               Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource GrassGreen}"
                                               FontSize="12" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="LangPackSkipJaCheck"
                                              Content="既に日本語がある MOD は翻訳しない"
                                              IsChecked="True"
                                              Foreground="{StaticResource TextMain}"
                                              FontSize="11" Margin="0,0,0,6"/>
                                    <TextBlock Text="出力先(空欄=resourcepacks)"
                                               Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}"
                                               FontSize="10" Margin="0,0,0,2"/>
                                    <TextBox x:Name="LangPackOutPath"
                                             FontSize="11" Margin="0,0,0,6"
                                             Background="{StaticResource StoneDark}"
                                             Foreground="{StaticResource TextMain}"
                                             BorderThickness="0" Padding="4,2"/>
                                    <TextBlock x:Name="LangPackUsage"
                                               Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}"
                                               FontSize="10" Margin="0,0,0,4"
                                               TextWrapping="Wrap" Text=""/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button x:Name="LangPackGenBtn"
                                                Content="生成"
                                                Style="{StaticResource McButton}"
                                                Margin="0,0,6,0"
                                                Click="LangPackGenerate_Click"/>
                                        <Button x:Name="LangPackCancelBtn"
                                                Content="中断"
                                                Style="{StaticResource McButtonGray}"
                                                IsEnabled="False"
                                                Click="LangPackCancel_Click"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,4">
                                        <Button x:Name="LangPackRecheckBtn"
                                                Content="復元漏れ再検査"
                                                Style="{StaticResource McButtonGray}"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,4"
                                                Click="LangPackRecheck_Click"/>
                                        <Button x:Name="LangPackRepairPrintfBtn"
                                                Content="printf修復"
                                                Style="{StaticResource McButtonGray}"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,4"
                                                Click="LangPackRepairPrintf_Click"/>
                                        <Button x:Name="LangPackRetranslateBtn"
                                                Content="色コード再翻訳"
                                                Style="{StaticResource McButtonGray}"
                                                HorizontalAlignment="Stretch"
                                                Click="LangPackRetranslate_Click" Cursor=""/>
                                    </StackPanel>
                                    <ProgressBar x:Name="LangPackProgress"
                                                 Height="14" Margin="0,0,0,4"
                                                 Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{StaticResource GrassGreen}"
                                                 Background="{StaticResource StoneDark}"
                                                 Visibility="Collapsed"/>
                                    <TextBlock x:Name="LangPackStatus"
                                               Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}"
                                               FontSize="11"
                                               TextWrapping="Wrap" Text=""/>
                                </StackPanel>
                            </Border>


                            <TreeView x:Name="ModTree" Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="{StaticResource TextMain}"
                                      SelectedItemChanged="ModTree_SelectedItemChanged"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <Border Grid.Column="2" Background="{StaticResource BgDark}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4">
                                <!-- 左: 表示切替と並び順 -->
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Button Content="大" Style="{StaticResource McButtonGray}"
                                            Margin="0,0,6,0" Click="ViewLarge_Click"/>
                                    <Button Content="中" Style="{StaticResource McButtonGray}"
                                            Margin="0,0,6,0" Click="ViewMedium_Click"/>
                                    <Button Content="一覧" Style="{StaticResource McButtonGray}"
                                            Click="ViewList_Click"/>
                                    <TextBlock Text="並び順:" Style="{StaticResource PixelText}"
                                               VerticalAlignment="Center" Margin="16,0,4,0"/>
                                    <ComboBox x:Name="SortCombo" Width="160"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource McComboBox}"
                                              SelectionChanged="SortCombo_SelectionChanged">
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="名称順（昇順）" IsSelected="True"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="名称順（降順）"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="カテゴリ順"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="ファイル更新日順"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="ファイルサイズ順"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="追加日順"/>
                                        <ComboBoxItem Style="{StaticResource McComboBoxItem}"
                                                      Content="ローダー順"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- 右: 選択モード開始ボタンのみ -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="SelectModeBtn" Content="選択"
                                            Style="{StaticResource McButtonGray}"
                                            Click="SelectMode_Click"/>
                                </StackPanel>

                            </DockPanel>
                            <!-- 検索行 -->
                            <DockPanel DockPanel.Dock="Top" Margin="8,0,8,6">
                                <TextBlock Text="検索:" Style="{StaticResource PixelText}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            Margin="8,0,0,0">
                                    <RadioButton x:Name="SearchAndRadio" Content="AND"
                                                 GroupName="SearchMode" IsChecked="True"
                                                 Foreground="{StaticResource TextMain}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Checked="SearchMode_Changed"/>
                                    <RadioButton x:Name="SearchOrRadio" Content="OR"
                                                 GroupName="SearchMode"
                                                 Foreground="{StaticResource TextMain}"
                                                 VerticalAlignment="Center"
                                                 Checked="SearchMode_Changed"/>
                                </StackPanel>
                                <TextBox x:Name="SearchBox"
                                         Background="{StaticResource BgCard}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         BorderThickness="0" Padding="6,3"
                                         VerticalContentAlignment="Center"
                                         TextChanged="SearchBox_TextChanged"/>
                            </DockPanel>

                            <!-- ===== カバーアート帯（軽量カルーセル） ===== -->
                            <Border DockPanel.Dock="Top" Height="150" Margin="8,0,8,8"
                                    Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource StoneDark}" BorderThickness="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="CoverCanvas" ClipToBounds="True"
                                        Background="Transparent"
                                        SizeChanged="CoverCanvas_SizeChanged"
                                        MouseLeftButtonDown="CoverCanvas_MouseDown"
                                        MouseMove="CoverCanvas_MouseMove"
                                        MouseLeftButtonUp="CoverCanvas_MouseUp"
                                        MouseLeave="CoverCanvas_MouseLeave"/>
                            </Border>

                            <ListBox x:Name="CardList" Background="Transparent"
                                     BorderThickness="0" Padding="6"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="CardList_SelectionChanged"
                                     ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                     HorizontalContentAlignment="Stretch"/>


                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <Border Grid.Column="4" Background="{StaticResource BgPanel}" Padding="12">
                        <Grid>
                            <!-- ===== 詳細パネル（通常モード） ===== -->
                            <ScrollViewer x:Name="DetailPanel" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="詳細" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource GrassGreen}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="DetailName" Style="{StaticResource PixelText}"
                                               FontSize="16" TextWrapping="Wrap" Text="(MODを選択)"/>
                                    <TextBlock x:Name="DetailId" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}" Margin="0,8,0,0"/>
                                    <TextBlock x:Name="DetailVersion" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="DetailLoader" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}" Margin="0,4,0,12"/>
                                    <TextBlock x:Name="DetailCategory" Style="{StaticResource PixelText}"
                                               TextWrapping="Wrap" Margin="0,2,0,0"/>

                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="説明"
                                                   Style="{StaticResource PixelText}"
                                                   Foreground="{StaticResource GrassGreen}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="TranslateBtn" Content="翻訳"
                                                Style="{StaticResource McButtonGray}"
                                                Click="Translate_Click"/>
                                    </Grid>
                                    <wv2:WebView2 x:Name="DetailWeb" Height="320"
                                                  Margin="0,4,0,12"/>

                                    <TextBlock Text="MODページ" Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource GrassGreen}"/>
                                    <TextBlock x:Name="UrlCurseForge" Style="{StaticResource PixelText}"
                                               Foreground="#E69138" TextWrapping="Wrap"
                                               Cursor="Hand" Margin="0,4,0,0"
                                               MouseLeftButtonUp="UrlCf_Click"
                                               Text="CurseForge: (なし)"/>
                                    <TextBlock x:Name="UrlModrinth" Style="{StaticResource PixelText}"
                                               Foreground="#1BD96A" TextWrapping="Wrap"
                                               Cursor="Hand" Margin="0,4,0,0"
                                               MouseLeftButtonUp="UrlMr_Click"
                                               Text="Modrinth: (なし)"/>
                                    <Button x:Name="RefetchBtn" Content="このMODを再取得"
                                            Style="{StaticResource McButtonGray}"
                                            HorizontalAlignment="Left" Margin="0,16,0,0"
                                            Click="Refetch_Click"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ===== 取得モードパネル ===== -->
                            <DockPanel x:Name="SelectionPanel" Visibility="Collapsed">
                                <TextBlock DockPanel.Dock="Top" Text="取得モード"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" Margin="0,0,0,10"/>

                                <!-- ボタン: 上2行は2列、最下行に選択終了 -->
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Content="全選択"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="0,0,4,4" Click="SelectAll_Click"/>
                                    <Button Grid.Row="0" Grid.Column="1" Content="全解除"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="4,0,0,4" Click="SelectNone_Click"/>
                                    <Button Grid.Row="1" Grid.Column="0" x:Name="RefetchSelectedBtn"
                                            Content="選択を再取得(0件)"
                                            Style="{StaticResource McButton}"
                                            Margin="0,4,4,4" Click="RefetchSelected_Click"/>
                                    <Button Grid.Row="1" Grid.Column="1" x:Name="OllamaSelectedBtn"
                                            Content="Ollama取得(0件)"
                                            Style="{StaticResource McButton}"
                                            Margin="4,4,0,4" Click="OllamaSelected_Click"/>
                                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                            Content="選択終了"
                                            Style="{StaticResource McButtonRed}"
                                            Margin="0,4,0,0" Click="SelectMode_Click"/>
                                </Grid>

                                <TextBlock DockPanel.Dock="Top" Text="選択中のMOD"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" Margin="0,0,0,6"/>

                                <!-- 選択中MOD一覧（一覧表示と同じ ListTemplate） -->
                                <ListBox x:Name="SelectedList" Background="Transparent"
                                         BorderThickness="0" Padding="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                         HorizontalContentAlignment="Stretch"
                                         ItemTemplate="{StaticResource ListTemplate}"
                                         SelectionChanged="SelectedList_SelectionChanged"/>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Tab 2: クラッシュレポート ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="380" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左: クラッシュレポートのファイル一覧 -->
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <DockPanel>
                            <Button DockPanel.Dock="Top" Content="← 戻る"
                                    Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Margin="10"
                                    Click="Back_Click"/>
                            <TextBlock DockPanel.Dock="Top" Text="クラッシュレポート"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"
                                       Margin="10,0,10,6"/>
                            <Button DockPanel.Dock="Top" Content="このレポートを解析"
                                    Style="{StaticResource McButton}"
                                    Margin="10,0,10,10" Click="AnalyzeCrash_Click"/>
                            <ListBox x:Name="CrashFileList" Background="Transparent"
                                     BorderThickness="0" Foreground="{StaticResource TextMain}"
                                     SelectionChanged="CrashFile_Selected"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <!-- 中央: 解析した issue 一覧 -->
                    <Border Grid.Column="2" Background="{StaticResource BgDark}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" x:Name="CrashSummary"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Margin="10,10,10,8"
                                       Text="(レポートを選び「このレポートを解析」を押してください)"/>
                            <ListBox x:Name="CrashIssueList" Background="Transparent"
                                     BorderThickness="0" Padding="6"
                                     Foreground="{StaticResource TextMain}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ItemContainerStyle="{StaticResource TransparentListBoxItem}"
                                     HorizontalContentAlignment="Stretch"
                                     SelectionChanged="CrashIssueList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgCard}"
                                                BorderBrush="{StaticResource StoneDark}"
                                                BorderThickness="1" Margin="0,0,0,4"
                                                Padding="8,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding KindLabel}"
                                                           FontFamily="{StaticResource PixelFont}"
                                                           Foreground="{StaticResource GrassGreen}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding ModId}"
                                                           FontFamily="{StaticResource PixelFont}"
                                                           Foreground="{StaticResource TextMain}"
                                                           FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource StoneDark}"/>

                    <!-- 右: 選択 issue の詳細パネル -->
                    <Border Grid.Column="4" Background="{StaticResource BgPanel}" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="詳細" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" Margin="0,0,0,10"/>

                                <!-- クラッシュ理由 -->
                                <TextBlock Text="クラッシュ原因" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" FontSize="12"/>
                                <TextBox x:Name="CrashDetailReason"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         IsTabStop="False"
                                         Margin="0,4,0,12"
                                         Text="(中央のリストから問題を選択)"/>


                                <!-- MOD情報(スキャン済みなら表示) -->
                                <TextBlock Text="MOD情報" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" FontSize="12"/>
                                <TextBlock x:Name="CrashDetailName" Style="{StaticResource PixelText}"
                                           FontSize="15" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="―"/>
                                <TextBlock x:Name="CrashDetailId" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CrashDetailVersion" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CrashDetailLoader" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CrashDetailCategory" Style="{StaticResource PixelText}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CrashDetailFile" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,8,0,12"/>

                                <!-- MODページ -->
                                <TextBlock Text="MODページ" Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}" FontSize="12"/>
                                <TextBlock x:Name="CrashUrlCurseForge" Style="{StaticResource PixelText}"
                                           Foreground="#E69138" TextWrapping="Wrap"
                                           Cursor="Hand" Margin="0,4,0,0"
                                           MouseLeftButtonUp="CrashUrlCf_Click"
                                           Text="CurseForge: ―"/>
                                <TextBlock x:Name="CrashUrlModrinth" Style="{StaticResource PixelText}"
                                           Foreground="#1BD96A" TextWrapping="Wrap"
                                           Cursor="Hand" Margin="0,4,0,0"
                                           MouseLeftButtonUp="CrashUrlMr_Click"
                                           Text="Modrinth: ―"/>

                                <!-- 削除ボタン(第3段階で実装) -->
                                <Button x:Name="CrashDeleteBtn" Content="このMODを削除"
                                        Style="{StaticResource McButtonRed}"
                                        HorizontalAlignment="Left" Margin="0,20,0,0"
                                        IsEnabled="False"
                                        Click="CrashDelete_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- ===== Tab 3: 設定 ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <StackPanel Margin="10">
                            <Button Content="← 戻る" Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Click="Back_Click"/>
                            <TextBlock Text="設定" FontSize="18" Margin="0,20,0,0"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgDark}" Padding="24">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text=".minecraft フォルダ" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <Grid Margin="0,4,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="PathBox" IsReadOnly="True"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="選択..."
                                        Style="{StaticResource McButtonGray}"
                                        Margin="8,0,0,0" Click="SelectFolder_Click"/>
                            </Grid>

                            <TextBlock Text="CurseForge APIキー" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <PasswordBox x:Name="CfKeyBox" Margin="0,4,0,16"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"/>

                            <TextBlock Text="DeepL APIキー" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <PasswordBox x:Name="DeepLKeyBox" Margin="0,4,0,16"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         BorderThickness="0" Padding="6"/>

                            <Button Content="保存" Style="{StaticResource McButton}"
                                    HorizontalAlignment="Left" Click="SaveSettings_Click"/>
                            <TextBlock x:Name="SettingsStatus" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" Margin="0,10,0,0"/>

                            <TextBlock Text="キャッシュ管理" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}" Margin="0,28,0,0"/>
                            <TextBlock Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,4,0,8"
                                       Text="MOD情報とアイコンの保存データを全て削除します。次回スキャンで再取得されます。"/>
                            <Button Content="キャッシュを全削除" Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Click="ClearCache_Click"/>
                            <TextBlock x:Name="CacheStatus" Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" Margin="0,8,0,0"/>

                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- ===== Tab 4: 建築モード（Mine Architect / 最小実験） ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <StackPanel Margin="10">
                            <Button Content="← 戻る" Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Click="Back_Click"/>
                            <TextBlock Text="建築モード" FontSize="18" Margin="0,20,0,0"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <TextBlock Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,8,0,0"
                                       Text="自然言語の指示と使用ブロックから、建物・曲面・生成AIの3案を生成し、3Dプレビューで確認します。"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgDark}" Padding="24">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="モード"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <ComboBox x:Name="ArchKindCombo" Margin="0,4,0,12"
                                          Style="{StaticResource McComboBox}"
                                          ItemContainerStyle="{StaticResource McComboBoxItem}"
                                          SelectedIndex="0"
                                          SelectionChanged="ArchKind_SelectionChanged">
                                    <ComboBoxItem Content="簡易建築（家・建物）"/>
                                    <ComboBoxItem Content="生成AI（GLBから）"/>
                                </ComboBox>

                                <TextBlock Text="正面の向き（ファサード神殿のとき）"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <ComboBox x:Name="ArchFacadeCombo" Margin="0,4,0,12"
                                          Style="{StaticResource McComboBox}"
                                          ItemContainerStyle="{StaticResource McComboBoxItem}"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="南 (south)" Tag="south"/>
                                    <ComboBoxItem Content="北 (north)" Tag="north"/>
                                    <ComboBoxItem Content="東 (east)" Tag="east"/>
                                    <ComboBoxItem Content="西 (west)" Tag="west"/>
                                </ComboBox>


                                <TextBlock Text="ジャンル"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <ComboBox x:Name="ArchGenreCombo" Margin="0,4,0,12"
                                          Style="{StaticResource McComboBox}"
                                          ItemContainerStyle="{StaticResource McComboBoxItem}"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="ArchGenre_SelectionChanged"/>

                                <TextBlock Text="モデル名"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>

                                <DockPanel Margin="0,4,0,12">
                                    <Button DockPanel.Dock="Right" x:Name="ArchModelRefreshBtn"
                                            Content="再取得" Style="{StaticResource McButtonGray}"
                                            Margin="6,0,0,0" Click="ArchModelRefresh_Click"/>
                                    <ComboBox x:Name="ArchModelCombo"
                                              Style="{StaticResource McComboBox}"
                                              ItemContainerStyle="{StaticResource McComboBoxItem}"
                                              VerticalAlignment="Center"/>
                                </DockPanel>

                                <TextBlock Text="使用可能ブロック"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBlock x:Name="ArchBlocksSummary"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,4,0,4"
                                           Text="(未選択)"/>
                                <TextBox x:Name="ArchBlocksBox" Visibility="Collapsed"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         BorderThickness="0" Padding="6" Margin="0,0,0,0"
                                         TextWrapping="Wrap" AcceptsReturn="True" Height="48"
                                         Text="minecraft:oak_planks, minecraft:oak_log, minecraft:glass, minecraft:cobblestone"/>

                                <Button x:Name="ArchPickBlocksBtn"
                                        Content="ブロックを選択..." Style="{StaticResource McButtonGray}"
                                        HorizontalAlignment="Left" Margin="0,0,0,12"
                                        Click="ArchPickBlocks_Click"/>

                                <!-- 建築/プリミティブ用のサイズ3欄。生成AIモードでは隠す。 -->
                                <StackPanel x:Name="ArchSizePanel">
                                    <TextBlock Text="サイズ（幅 × 奥行 × 高さ）"
                                   Style="{StaticResource PixelText}"
                                   Foreground="{StaticResource GrassGreen}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                                        <TextBlock Text="幅" Style="{StaticResource PixelText}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox x:Name="ArchWidthBox" Width="48"
                                     Background="{StaticResource BgPanel}"
                                     Foreground="{StaticResource TextMain}"
                                     FontFamily="{StaticResource PixelFont}"
                                     BorderThickness="0" Padding="4"
                                     VerticalContentAlignment="Center"
                                     Text="5"/>
                                        <TextBlock Text="×" Style="{StaticResource PixelText}"
                                       VerticalAlignment="Center" Margin="6,0,6,0"/>
                                        <TextBox x:Name="ArchDepthBox" Width="48"
                                     Background="{StaticResource BgPanel}"
                                     Foreground="{StaticResource TextMain}"
                                     FontFamily="{StaticResource PixelFont}"
                                     BorderThickness="0" Padding="4"
                                     VerticalContentAlignment="Center"
                                     Text="5"/>
                                        <TextBlock Text="×" Style="{StaticResource PixelText}"
                                       VerticalAlignment="Center" Margin="6,0,6,0"/>
                                        <TextBox x:Name="ArchHeightBox" Width="48"
                                     Background="{StaticResource BgPanel}"
                                     Foreground="{StaticResource TextMain}"
                                     FontFamily="{StaticResource PixelFont}"
                                     BorderThickness="0" Padding="4"
                                     VerticalContentAlignment="Center"
                                     Text="4"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 生成AI用の解像度選択。建築/プリミティブでは隠す。 -->
                                <StackPanel x:Name="ArchResolutionPanel" Visibility="Collapsed">
                                    <TextBlock Text="解像度（ボクセルの細かさ）"
                                   Style="{StaticResource PixelText}"
                                   Foreground="{StaticResource GrassGreen}"/>
                                    <ComboBox x:Name="ArchResolutionCombo" Margin="0,4,0,12"
                                  Style="{StaticResource McComboBox}"
                                  ItemContainerStyle="{StaticResource McComboBoxItem}"
                                  SelectedIndex="5">
                                        <ComboBoxItem Content="9（小屋サイズ）" Tag="9"/>
                                        <ComboBoxItem Content="12（極小・置物サイズ）" Tag="12"/>
                                        <ComboBoxItem Content="16（小さい）" Tag="16"/>
                                        <ComboBoxItem Content="24（やや小さい）" Tag="24"/>
                                        <ComboBoxItem Content="32（粗い・軽い）" Tag="32"/>
                                        <ComboBoxItem Content="48（標準）" Tag="48"/>
                                        <ComboBoxItem Content="64（精細・重い）" Tag="64"/>
                                        <ComboBoxItem Content="96（高精細）" Tag="96"/>
                                        <ComboBoxItem Content="128（最高・かなり重い）" Tag="128"/>
                                    </ComboBox>
                                </StackPanel>

                                <CheckBox x:Name="ArchWindowToggle" IsChecked="True"
                                          Content="窓をつける"
                                          Foreground="{StaticResource TextMain}"
                                          FontFamily="{StaticResource PixelFont}"
                                          Margin="0,0,0,8"/>

                                <TextBlock Text="作りたいものの指示（窓・ドア・雰囲気など）"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBox x:Name="ArchPromptBox"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         BorderThickness="0" Padding="6" Margin="0,4,0,12"
                                         TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                         Text="木の小屋。南にドア、東西に窓を少し。三角屋根。"/>
                                
                                <TextBlock Text="画像生成に常に付ける定型ワード（英語・3D化向け）"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBox x:Name="ArchFixedWordsBox"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         BorderThickness="0" Padding="6" Margin="0,4,0,12"
                                         TextWrapping="Wrap" AcceptsReturn="True" Height="44"
                                         Text="centered, single object, plain background, isometric view, full view, highly detailed"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="ArchGenBtn"
                                            Content="3案を生成" Style="{StaticResource McButton}"
                                            Click="ArchGenerate_Click"/>
                                    <Button x:Name="ArchGalleryBtn" Content="画像ギャラリー"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="8,0,0,0"
                                            Click="ArchGallery_Click" Cursor=""/>
                                </StackPanel>
                                
                                <TextBlock x:Name="ArchStatus"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,0,0,8" Text=""/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="ArchCase1Btn" Content="案1"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="0,0,6,0" IsEnabled="False"
                                            Click="ArchCase_Click" Tag="0"/>
                                    <Button x:Name="ArchCase2Btn" Content="案2"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="0,0,6,0" IsEnabled="False"
                                            Click="ArchCase_Click" Tag="1"/>
                                    <Button x:Name="ArchCase3Btn" Content="案3"
                                            Style="{StaticResource McButtonGray}"
                                            IsEnabled="False"
                                            Click="ArchCase_Click" Tag="2"/>
                                </StackPanel>

                                <TextBlock Text="出力ファイル名（schematics に保存）"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBox x:Name="ArchNameBox"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         BorderThickness="0" Padding="6" Margin="0,4,0,8"
                                         VerticalContentAlignment="Center"
                                         Text="building"/>

                                <Button x:Name="ArchExportBtn"
                                        Content="表示中の案を schematics に出力"
                                        Style="{StaticResource McButton}"
                                        HorizontalAlignment="Left" Margin="0,0,0,8"
                                        IsEnabled="False"
                                        Click="ArchExport_Click"/>

                                <Button x:Name="ArchOpenPreviewBtn"
                            Content="3Dプレビューを開く"
                            Style="{StaticResource McButtonGray}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Click="ArchOpenPreview_Click"/>

                                <!-- 長時間処理の進捗バー。確定進捗(パレット生成)と
                                     不定進捗(生成・3D化)の両方をここで使い回す。 -->
                                <Grid x:Name="ArchProgressArea" Visibility="Collapsed"
                                      Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ProgressBar x:Name="ArchProgressBar" Grid.Row="0"
                                                 Height="14" Minimum="0" Maximum="100"
                                                 Background="{StaticResource BgPanel}"
                                                 Foreground="{StaticResource GrassGreen}"
                                                 BorderThickness="0"/>
                                    <TextBlock x:Name="ArchProgressText" Grid.Row="1"
                                               Style="{StaticResource PixelText}"
                                               Foreground="{StaticResource TextDim}"
                                               FontSize="11" Margin="0,2,0,0" Text=""/>
                                </Grid>

                                <TextBlock Text="生出力 / パース結果"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBox x:Name="ArchResultBox" IsReadOnly="True"
                                         Height="240"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}" FontSize="11"
                                         BorderThickness="0" Padding="6" Margin="0,4,0,0"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Tab 5: Create機械生成（独立パネル） ===== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}">
                        <StackPanel Margin="10">
                            <Button Content="← 戻る" Style="{StaticResource McButtonGray}"
                                    HorizontalAlignment="Left" Click="Back_Click"/>
                            <TextBlock Text="Create機械" FontSize="18" Margin="0,20,0,0"
                                       Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource GrassGreen}"/>
                            <TextBlock Style="{StaticResource PixelText}"
                                       Foreground="{StaticResource TextDim}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,8,0,0"
                                       Text="自然言語の指示と空間サイズから、向きの揃った動力機械の骨格を生成し、構造NBTとして出力します。"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgDark}" Padding="24">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Cursor="">
                                <TextBlock Text="作りたい機械の指示"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBox x:Name="MachinePromptBox"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         BorderThickness="0" Padding="6" Margin="0,4,0,12"
                                         TextWrapping="Wrap" AcceptsReturn="True" Height="70"
                                         Text="水力で回る動力源モジュールを作って。water_wheelで動力を生み、shaftやcogwheelで動力を取り出せるようにする。出力位置の目印として lime_wool を1つ置く。"/>

                                <TextBlock Text="出力ファイル名（schematics に保存）"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBox x:Name="MachineNameBox"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}"
                                         BorderThickness="0" Padding="6" Margin="0,4,0,12"
                                         VerticalContentAlignment="Center"
                                         Text="module_machine"/>

                                <TextBlock Text="LLMモデル（Ollama）"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <DockPanel Margin="0,4,0,12">
                                    <Button DockPanel.Dock="Right" x:Name="MachineModelReloadBtn"
                                            Content="再読込" Style="{StaticResource McButtonGray}"
                                            Margin="6,0,0,0" Click="MachineModelReload_Click"/>
                                    <ComboBox x:Name="MachineModelCombo"
                                              Style="{StaticResource McComboBox}"
                                              ItemContainerStyle="{StaticResource McComboBoxItem}"
                                              VerticalAlignment="Center"/>
                                </DockPanel>

                                <TextBlock Text="作るジャンル（複数選択可。単一が基本）"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <WrapPanel Margin="0,4,0,12">
                                    <CheckBox x:Name="GenrePowerSource" Content="動力源"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                    <CheckBox x:Name="GenrePowerTransmit" Content="動力伝達・分配"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                    <CheckBox x:Name="GenrePowerControl" Content="動力制御"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                    <CheckBox x:Name="GenreProcessing" Content="加工"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                    <CheckBox x:Name="GenreStorage" Content="保管"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                    <CheckBox x:Name="GenreFluid" Content="流体"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                    <CheckBox x:Name="GenreContraption" Content="可動・構造"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                    <CheckBox x:Name="GenreMeter" Content="計測・表示"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                    <CheckBox x:Name="GenreRedstone" Content="レッドストーン連動"
                                              Foreground="{StaticResource TextMain}"
                                              FontFamily="{StaticResource PixelFont}"
                                              Margin="0,0,12,4"/>
                                </WrapPanel>

                                <TextBlock Text="空間サイズ（X × Y × Z）"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                                    <TextBlock Text="X" Style="{StaticResource PixelText}"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox x:Name="MachineSizeXBox" Width="48"
                                             Background="{StaticResource BgPanel}"
                                             Foreground="{StaticResource TextMain}"
                                             FontFamily="{StaticResource PixelFont}"
                                             BorderThickness="0" Padding="4"
                                             VerticalContentAlignment="Center" Text="5"/>
                                    <TextBlock Text="×" Style="{StaticResource PixelText}"
                                               VerticalAlignment="Center" Margin="6,0,6,0"/>
                                    <TextBox x:Name="MachineSizeYBox" Width="48"
                                             Background="{StaticResource BgPanel}"
                                             Foreground="{StaticResource TextMain}"
                                             FontFamily="{StaticResource PixelFont}"
                                             BorderThickness="0" Padding="4"
                                             VerticalContentAlignment="Center" Text="5"/>
                                    <TextBlock Text="×" Style="{StaticResource PixelText}"
                                               VerticalAlignment="Center" Margin="6,0,6,0"/>
                                    <TextBox x:Name="MachineSizeZBox" Width="48"
                                             Background="{StaticResource BgPanel}"
                                             Foreground="{StaticResource TextMain}"
                                             FontFamily="{StaticResource PixelFont}"
                                             BorderThickness="0" Padding="4"
                                             VerticalContentAlignment="Center" Text="5"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="MachineGenBtn"
                                            Content="機械を生成" Style="{StaticResource McButton}"
                                            Click="MachineGenerate_Click"/>
                                    <Button x:Name="MachineOpenPreviewBtn"
                                            Content="3Dビューを開く"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="8,0,0,0"
                                            Click="MachineOpenPreview_Click"/>
                                    <Button x:Name="MachineOpenFolderBtn"
                                            Content="出力フォルダを開く"
                                            Style="{StaticResource McButtonGray}"
                                            Margin="8,0,0,0"
                                            Click="MachineOpenFolder_Click"/>
                                </StackPanel>

                                <TextBlock x:Name="MachineStatus"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource TextDim}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,0,0,8" Text="" Cursor=""/>

                                <TextBlock Text="生成結果"
                                           Style="{StaticResource PixelText}"
                                           Foreground="{StaticResource GrassGreen}"/>
                                <TextBox x:Name="MachineResultBox" IsReadOnly="True"
                                         Height="300"
                                         Background="{StaticResource BgPanel}"
                                         Foreground="{StaticResource TextMain}"
                                         FontFamily="{StaticResource PixelFont}" FontSize="11"
                                         BorderThickness="0" Padding="6" Margin="0,4,0,0"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <Border Grid.Row="1" Background="{StaticResource BgPanel}" Height="120">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="ログ" Padding="10,4"
                           Style="{StaticResource PixelText}"
                           Foreground="{StaticResource GrassGreen}"/>
                <TextBox x:Name="LogBox" IsReadOnly="True"
                         Background="{StaticResource BgDark}"
                         Foreground="{StaticResource TextMain}" BorderThickness="0"
                         FontFamily="{StaticResource PixelFont}" FontSize="11"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         Padding="10,0,10,8"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
