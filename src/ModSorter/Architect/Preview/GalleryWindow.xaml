<Window x:Class="ModSorter.Architect.Preview.GalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画像ギャラリー" Height="600" Width="960"
        Background="#1c1c1c" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" Grid.Row="0"
                   Foreground="#dddddd" FontSize="13" Margin="2,2,2,8"
                   Text="読み込み中..."/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="ImagesPanel" Orientation="Horizontal"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="2,8,2,2">
            <Button x:Name="RefreshBtn" Content="再読込" Width="90" Height="32"
                    Margin="4,0" Click="Refresh_Click"/>
            <Button x:Name="DeleteBtn" Content="選択を削除" Width="110" Height="32"
                    Margin="4,0" Click="Delete_Click"/>
            <Button x:Name="SculptBtn" Content="選択を3D化" Width="120" Height="32"
                    Margin="4,0" Click="Sculpt_Click"/>
            <Button x:Name="CloseBtn" Content="閉じる" Width="90" Height="32"
                    Margin="4,0" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
