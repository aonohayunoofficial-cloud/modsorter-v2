<Window x:Class="ModSorter.Architect.Preview.ImagePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画像を選択" Height="520" Width="900"
        Background="#1c1c1c" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 上部: 状態表示 -->
        <TextBlock x:Name="StatusText" Grid.Row="0"
                   Foreground="#9fd39f" FontFamily="Consolas" FontSize="13"
                   Text="画像を生成中..." Margin="0,0,0,8"/>

        <!-- 中央: 画像3枚を横並び -->
        <UniformGrid x:Name="ImagesPanel" Grid.Row="1" Rows="1" Columns="3">
            <!-- 画像ボタンはコードビハインドで動的に追加する -->
        </UniformGrid>

        <!-- 下部: 操作ボタン -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock x:Name="SelectionInfo"
                       Foreground="#9fd39f" FontFamily="Consolas" FontSize="12"
                       VerticalAlignment="Center" Margin="0,0,16,0"
                       Text="選択: 0 枚"/>
            <Button x:Name="DecideBtn" Content="決定（3D化へ）"
                    Width="150" Height="34" Margin="0,0,8,0"
                    IsEnabled="False" Click="Decide_Click"/>
            <Button x:Name="RetakeBtn" Content="リテイク（作り直す）"
                    Width="160" Height="34" Margin="0,0,8,0"
                    Click="Retake_Click"/>
            <Button x:Name="CancelBtn" Content="キャンセル"
                    Width="120" Height="34"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
