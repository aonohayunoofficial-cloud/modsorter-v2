<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ModSorter">

    <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

    <!-- 配色: Minecraftの石・土・草を意識した自作パレット -->
    <SolidColorBrush x:Key="BgDark"      Color="#1E1B17"/>
    <SolidColorBrush x:Key="BgPanel"     Color="#2B2620"/>
    <SolidColorBrush x:Key="BgCard"      Color="#3A332B"/>
    <SolidColorBrush x:Key="BgCardHover" Color="#4A4136"/>
    <SolidColorBrush x:Key="StoneLight"  Color="#8B8B8B"/>
    <SolidColorBrush x:Key="StoneDark"   Color="#3F3F3F"/>
    <SolidColorBrush x:Key="GrassGreen"  Color="#7FB238"/>
    <SolidColorBrush x:Key="GrassDark"   Color="#5C8228"/>
    <SolidColorBrush x:Key="TextMain"    Color="#E8E0D4"/>
    <SolidColorBrush x:Key="TextDim"     Color="#9A8F7E"/>

    <!-- フォント: Monocraftが無ければ Consolas にフォールバック -->
    <FontFamily x:Key="PixelFont">/Fonts/#Monocraft, Consolas, Lucida Console</FontFamily>

    <!-- Minecraft風ボタン(緑・主要操作) -->
    <Style x:Key="McButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource PixelFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="Background" Value="{StaticResource GrassGreen}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{StaticResource GrassDark}" Padding="0,0,2,2">
                        <Border x:Name="inner" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="inner" Property="Background" Value="#8FC840"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="inner" Property="Background" Value="{StaticResource GrassDark}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- グレー版ボタン(副次操作用) -->
    <Style x:Key="McButtonGray" TargetType="Button" BasedOn="{StaticResource McButton}">
        <Setter Property="Background" Value="{StaticResource StoneLight}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{StaticResource StoneDark}" Padding="0,0,2,2">
                        <Border x:Name="inner" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="inner" Property="Background" Value="#A5A5A5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ピクセル風テキスト -->
    <Style x:Key="PixelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PixelFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
    </Style>

    <!-- カード(Steam風) -->
    <Style x:Key="ModCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource StoneDark}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Margin" Value="6"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BgCardHover}"/>
                <Setter Property="BorderBrush" Value="{StaticResource GrassGreen}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 大カード -->
    <DataTemplate x:Key="CardLargeTemplate">
        <Grid Width="220" Height="180">
            <Border x:Name="cardBorder" Style="{StaticResource ModCard}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="100" Background="{StaticResource StoneDark}">
                        <Grid>
                            <TextBlock Text="MOD" FontSize="26" FontFamily="{StaticResource PixelFont}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDim}"/>
                            <Image Stretch="Uniform" Source="{Binding IconSource}"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding DisplayName}" FontFamily="{StaticResource PixelFont}"
                               Foreground="{StaticResource TextMain}" TextWrapping="Wrap"
                               Margin="0,6,0,0" FontSize="13"/>
                </DockPanel>
            </Border>
            <!-- 選択モード中のみ表示するチェックボックス(左上) -->
            <CheckBox HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="12,12,0,0"
                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                      IsHitTestVisible="False"
                      Visibility="{Binding SelectionMode, Converter={StaticResource BoolToVis}}"/>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter TargetName="cardBorder" Property="BorderBrush" Value="#4A90E2"/>
                <Setter TargetName="cardBorder" Property="BorderThickness" Value="3"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- 中カード -->
    <DataTemplate x:Key="CardMediumTemplate">
        <Grid Width="150" Height="130">
            <Border x:Name="cardBorder" Style="{StaticResource ModCard}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="64" Background="{StaticResource StoneDark}">
                        <Grid>
                            <TextBlock Text="MOD" FontSize="18" FontFamily="{StaticResource PixelFont}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDim}"/>
                            <Image Stretch="Uniform" Source="{Binding IconSource}"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding DisplayName}" FontFamily="{StaticResource PixelFont}"
                               Foreground="{StaticResource TextMain}" TextWrapping="Wrap"
                               Margin="0,4,0,0" FontSize="11"/>
                </DockPanel>
            </Border>
            <CheckBox HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="8,8,0,0"
                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                      IsHitTestVisible="False"
                      Visibility="{Binding SelectionMode, Converter={StaticResource BoolToVis}}"/>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter TargetName="cardBorder" Property="BorderBrush" Value="#4A90E2"/>
                <Setter TargetName="cardBorder" Property="BorderThickness" Value="3"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- 一覧表示(画像なし・縦並び) -->
    <DataTemplate x:Key="ListTemplate">
        <Border Padding="8,5" Cursor="Hand" Margin="2,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource BgCard}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgCardHover}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                           FontFamily="{StaticResource PixelFont}"
                           Foreground="{StaticResource TextMain}" FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding Version}"
                           FontFamily="{StaticResource PixelFont}"
                           Foreground="{StaticResource TextDim}" FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" Text="{Binding Loader}"
                           FontFamily="{StaticResource PixelFont}"
                           Foreground="{StaticResource TextDim}" FontSize="11"/>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- ListBoxItem: 選択・ホバーの標準ハイライトを無効化 -->
    <Style x:Key="TransparentListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ComboBox ダークテーマ ===== -->

    <!-- ドロップダウンを開閉するトグルボタン部分 -->
    <ControlTemplate x:Key="McComboToggle" TargetType="ToggleButton">
        <Border x:Name="border"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource StoneDark}"
                BorderThickness="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Path x:Name="arrow" Grid.Column="1"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="{StaticResource TextMain}"/>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource BgCardHover}"/>
                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GrassGreen}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GrassGreen}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ComboBox本体 -->
    <Style x:Key="McComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontFamily" Value="{StaticResource PixelFont}"/>
        <Setter Property="Background" Value="{StaticResource BgCard}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Template="{StaticResource McComboToggle}"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="8,0,24,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource BgPanel}"
                                    BorderBrush="{StaticResource StoneDark}"
                                    BorderThickness="2">
                                <ScrollViewer>
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="DropDownBorder" Property="MinHeight" Value="20"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ドロップダウン内の各項目 -->
    <Style x:Key="McComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontFamily" Value="{StaticResource PixelFont}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BgCardHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource GrassDark}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 赤ボタン（選択終了など） ===== -->
    <Style x:Key="McButtonRed" TargetType="Button" BasedOn="{StaticResource McButton}">
        <Setter Property="Background" Value="#B23B3B"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="#7A2222" Padding="0,0,2,2">
                        <Border x:Name="inner" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="inner" Property="Background" Value="#C84A4A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="inner" Property="Background" Value="#922F2F"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>